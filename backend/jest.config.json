{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/src", "<rootDir>/services", "<rootDir>/services/order-service/src"],
  "testMatch": ["**/__tests__/**/*.ts", "**/?(*.)+(spec|test).ts"],
  "transform": {
    "^.+\\.ts$": ["ts-jest", {
      "tsconfig": {
        "types": ["node", "jest"]
      }
    }]
  },
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/**/*.d.ts",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts",
    "!src/**/examples.ts",
    "!src/index.ts",
    "!src/database/**",
    "!src/entities/**",
    "!src/handlers/**",
    "!src/middleware/**",
    "!src/routes/**",
    "!src/services/CartService.ts",
    "!src/services/NotificationService.ts",
    "!src/services/OrderService.ts",
    "!src/services/ProductService.ts",
    "!src/services/payment/**",
    "!src/services/dynamodb/index.ts",
    "!src/services/dynamodb/repositories/index.ts",
    "!src/services/s3/index.ts",
    "!src/utils/sessionHelper.ts",
    "!src/utils/verify-s3-implementation.ts"
  ],
  "coverageThreshold": {
    "global": {
      "branches": 70,
      "functions": 80,
      "lines": 80,
      "statements": 80
    }
  },
  "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json", "node"]
}
